# Cloudflare Pages: 301 .html -> clean URL, then 200 clean URL -> .html
# Generated by scripts/generate-redirects.js

# 301: .html URLs redirect to clean canonical URLs
/index.html / 301
/blog/index.html /blog 301
/blog/:slug.html /blog/:slug 301
/:path.html /:path 301

# 200: clean URLs serve .html content (rewrite)
/ /index.html 200
/blog /blog/index.html 200
/blog/ /blog/index.html 200
/blog/:slug /blog/:slug.html 200
/:path /:path.html 200